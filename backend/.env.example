# ── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database (Docker) ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://prohuman:prohuman_secret@localhost:5432/prohuman_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback
FRONTEND_URL=http://localhost:3001

# ── WhatsApp Reminder Safety Controls ───────────────────────────────────────
# Keep disabled until your provider integration is fully tested.
WHATSAPP_ENABLE_REMINDER_SEND=false

# Comma-separated E.164 numbers allowed to receive reminders.
# Example: +919999999999,+918888888888
WHATSAPP_ALLOWED_REMINDER_NUMBERS=

# Hard cap per reminder call.
WHATSAPP_MAX_REMINDER_RECIPIENTS=5

# Duplicate reminder cooldown (same message + same recipient).
WHATSAPP_REMINDER_COOLDOWN_MINUTES=720
