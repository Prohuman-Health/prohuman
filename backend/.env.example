# Environment
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/prohuman_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=prohuman_db
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
